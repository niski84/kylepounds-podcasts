  {
   "start": 403.53,
   "end": 404.45,
   "text": "Tobacco cigarettes"
  },
  {
   "start": 404.45,
   "end": 405.41,
   "text": "And it gets in your clothes"
  },
  {
   "start": 405.41,
   "end": 406.03,
   "text": "And it gets in the,"
  },
  {
   "start": 406.17,
   "end": 407.33,
   "text": "In, like,"
  },
  {
   "start": 407.41,
   "end": 408.01,
   "text": "The buildings"
  },
  {
   "start": 408.01,
   "end": 409.11,
   "text": "And walls and stuff"
  },
  {
   "start": 409.11,
   "end": 410.89,
   "text": "And it has a distinct smell"
