  {
   "start": 399.26,
   "end": 400.64,
   "text": "Is really the motivation anyway."
  },
  {
   "start": 400.78,
   "end": 401.16,
   "text": "If you..."
  },
  {
   "start": 401.16,
   "end": 402.4,
   "text": "If you listen to these"
  },
  {
   "start": 402.4,
   "end": 403.72,
   "text": "Billionaires talk about money"
  },
  {
   "start": 403.72,
   "end": 404.34,
   "text": "They're always like"
  },
  {
   "start": 404.34,
   "end": 405.28,
   "text": "I don't care about money"
  },
  {
   "start": 405.28,
   "end": 406.32,
   "text": "I just like my job."
  },
  {
   "start": 406.86,
   "end": 407.96,
   "text": "And I think that's true"
  },
  {
   "start": 407.96,
   "end": 408.72,
   "text": "With a lot of them."
  },
  {
   "start": 409.16,
   "end": 410.22,
   "text": "They just like their job"
  },
  {
   "start": 410.22,
   "end": 410.86,
   "text": "And they just happen"
  },
  {
   "start": 410.86,
   "end": 411.6,
   "text": "To make a lot of money"
  },
  {
   "start": 411.6,
   "end": 412.78,
   "text": "And now they're sitting"
  },
  {
   "start": 412.78,
   "end": 413.56,
   "text": "On all this money"
  },
  {
   "start": 413.56,
   "end": 414.5,
   "text": "And they just don't want"
  },
  {
   "start": 414.5,
   "end": 415.08,
   "text": "To spend it"
  },
  {
   "start": 415.08,
   "end": 415.84,
   "text": "Because they don't want"
  },
  {
   "start": 415.84,
   "end": 416.8,
   "text": "To give too much of it away."
  },
  {
   "start": 417.2,
   "end": 418.18,
   "text": "Even though a lot of them"
  },
  {
   "start": 418.18,
   "end": 419.28,
   "text": "Are giving a lot of it away"
  },
  {
   "start": 419.28,
   "end": 423.84,
   "text": "Bill Gates"
  },
  {
   "start": 423.84,
   "end": 426.04,
   "text": "Has pledged"
  },
  {
   "start": 426.04,
   "end": 426.5,
   "text": "To give away"
  },
  {
   "start": 426.5,
   "end": 427.22,
   "text": "Half of his money"
  },
  {
   "start": 427.22,
   "end": 427.72,
   "text": "As well"
  },
  {
   "start": 427.72,
   "end": 428.2,
   "text": "And he's gotten"
  },
  {
   "start": 428.2,
   "end": 429.42,
   "text": "Like signed"
  },
  {
   "start": 429.42,
   "end": 429.84,
   "text": "A whole bunch"
  },
  {
   "start": 429.84,
   "end": 430.58,
   "text": "Of other billionaires"
  },
  {
   "start": 430.58,
   "end": 432.26,
   "text": "To join the thing"
  },
  {
   "start": 432.26,
   "end": 432.86,
   "text": "Where they give away"
  },
  {
   "start": 432.86,
   "end": 433.42,
   "text": "Half their money."
  },
  {
   "start": 433.94,
   "end": 435.04,
   "text": "He's within 10 years"
  },
  {
   "start": 435.04,
   "end": 435.58,
   "text": "Of his death"
  },
  {
   "start": 435.58,
   "end": 436.26,
   "text": "He's going to have"
  },
  {
   "start": 436.26,
   "end": 437.34,
   "text": "His foundation"
  },
  {
   "start": 437.34,
   "end": 438.68,
   "text": "Give away all of his money"
  },
  {
   "start": 438.68,
   "end": 439.22,
   "text": "And he's not going to"
  },
  {
   "start": 439.22,
   "end": 439.68,
   "text": "Give any of it"
  },
  {
   "start": 439.68,
   "end": 440.14,
   "text": "To his children."
  },
  {
   "start": 440.14,
   "end": 445.2,
   "text": "And if more billionaires"
  },
  {
   "start": 445.2,
   "end": 446.58,
   "text": "The problem is that"
  },
  {
   "start": 446.58,
   "end": 447.4,
   "text": "Billionaires aren't"
  },
  {
   "start": 447.4,
   "end": 448.1,
   "text": "Like Bill Gates"
  },
  {
   "start": 448.1,
   "end": 448.66,
   "text": "A lot of them"
  },
  {
   "start": 448.66,
   "end": 449.26,
   "text": "Like to hang on"
  },
  {
   "start": 449.26,
   "end": 449.62,
   "text": "To their money"
  },
  {
   "start": 449.62,
   "end": 450.1,
   "text": "And a lot of them"
  },
  {
   "start": 450.1,
   "end": 451.3,
   "text": "Like to do dangerous stuff"
  },
  {
   "start": 451.3,
   "end": 453.7,
   "text": "And so we should make"
  },
  {
   "start": 453.7,
   "end": 454.16,
   "text": "A law"
  },
  {
   "start": 454.16,
   "end": 456.28,
   "text": "That's passed"
  },
  {
   "start": 456.28,
   "end": 456.78,
   "text": "By the people"
  },
  {
   "start": 456.78,
   "end": 457.38,
   "text": "It has to be"
  },
  {
   "start": 457.38,
   "end": 458.46,
   "text": "Something that the people"
  },
  {
   "start": 458.46,
   "end": 459.94,
   "text": "I don't know how"
  },
  {
   "start": 459.94,
   "end": 460.68,
   "text": "Laws get passed"
  },
  {
   "start": 460.68,
   "end": 461.44,
   "text": "But we should figure out"
  },
  {
   "start": 461.44,
   "end": 462.46,
   "text": "A way to pass a law"
  },
  {
   "start": 462.46,
   "end": 463.28,
   "text": "Where there should be"
  },
  {
   "start": 463.28,
   "end": 463.98,
   "text": "No billionaires"
  },
  {
   "start": 463.98,
   "end": 464.52,
   "text": "In America"
  },
  {
   "start": 464.52,
   "end": 466.64,
   "text": "Because we could be"
  },
  {
   "start": 466.64,
   "end": 467.68,
   "text": "Throwing all that money"
  },
  {
   "start": 467.68,
   "end": 468.7,
   "text": "Back into circulation"
  },
  {
   "start": 468.7,
   "end": 470.54,
   "text": "And get it into"
  },
  {
   "start": 470.54,
   "end": 471.1,
   "text": "The charities"
  },
  {
   "start": 471.1,
   "end": 472.06,
   "text": "And then pump it"
  },
  {
   "start": 472.06,
   "end": 472.92,
   "text": "Back into the people"
  },
  {
   "start": 472.92,
   "end": 473.66,
   "text": "And kick start"
  },
  {
   "start": 473.66,
   "end": 474.8,
   "text": "Some new industries"
  },
  {
   "start": 474.8,
   "end": 475.88,
   "text": "That we need to get going"
  },
  {
   "start": 475.88,
   "end": 477.5,
   "text": "Like solar"
  },
  {
   "start": 477.5,
   "end": 479.56,
   "text": "Or maybe even"
  },
  {
   "start": 479.56,
   "end": 480.6,
   "text": "This free energy stuff"
  },
  {
   "start": 480.6,
   "end": 481.2,
   "text": "If any of these"
  },
  {
   "start": 481.2,
   "end": 481.78,
   "text": "Super scientists"
  },
  {
   "start": 481.78,
   "end": 482.48,
   "text": "Who have the free energy"
  },
  {
   "start": 482.48,
   "end": 484.06,
   "text": "Device have the balls"
  },
  {
   "start": 484.06,
   "end": 484.9,
   "text": "To actually"
  },
  {
   "start": 484.9,
   "end": 486.38,
   "text": "Here it is"
  },
  {
   "start": 486.38,
   "end": 487.84,
   "text": "If any free energy"
  },
  {
   "start": 487.84,
   "end": 488.8,
   "text": "People have anything"
  },
  {
   "start": 488.8,
   "end": 489.56,
   "text": "Give it to me"
  },
  {
   "start": 489.56,
   "end": 490.36,
   "text": "And I'll come out"
  },
  {
   "start": 490.36,
   "end": 490.78,
   "text": "To the world"
  },
  {
   "start": 490.78,
   "end": 491.36,
   "text": "With it"
  },
  {
   "start": 491.36,
   "end": 492.5,
   "text": "But we already have"
  },
  {
   "start": 492.5,
   "end": 493.42,
   "text": "Free energy by the way"
  },
  {
   "start": 493.42,
   "end": 494.76,
   "text": "If we just invested"
  },
  {
   "start": 494.76,
   "end": 495.62,
   "text": "In that we'd be fine"
  },
  {
   "start": 495.62,
   "end": 496.44,
   "text": "There's that little thing"
  },
  {
   "start": 496.44,
   "end": 497.52,
   "text": "That it's powering"
  },
  {
   "start": 497.52,
   "end": 498.68,
   "text": "All of Silicon Valley"
  },
  {
   "start": 498.68,
   "end": 500.22,
   "text": "It feeds off dirt"
  },
  {
   "start": 500.22,
   "end": 503.06,
   "text": "What's that thing called"
  },
  {
   "start": 503.06,
   "end": 505.32,
   "text": "I can't even remember"
  },
  {
   "start": 505.32,
   "end": 505.74,
   "text": "Fuck"
  },
  {
   "start": 505.74,
   "end": 506.18,
   "text": "Oh well"
  },
  {
   "start": 506.18,
   "end": 506.48,
   "text": "Whatever"
  },
  {
   "start": 506.48,
   "end": 508.24,
   "text": "Yeah so it's going to be"
  },
  {
   "start": 508.24,
   "end": 508.74,
   "text": "In houses"
  },
  {
   "start": 508.74,
   "end": 509.84,
   "text": "Pretty soon"
  },
  {
   "start": 509.84,
   "end": 510.4,
   "text": "In five years"
  },
  {
   "start": 510.4,
   "end": 510.92,
   "text": "We're all going to have"
  },
  {
   "start": 510.92,
   "end": 511.52,
   "text": "The free energy"
  },
  {
   "start": 511.52,
   "end": 511.82,
   "text": "So"
  },
  {
   "start": 511.82,
   "end": 515.48,
   "text": "So"
  },
  {
   "start": 515.48,
   "end": 517.78,
   "text": "But until then"
  },
  {
   "start": 517.78,
   "end": 518.26,
   "text": "To get all that"
  },
  {
   "start": 518.26,
   "end": 518.66,
   "text": "Kick started"
  },
  {
   "start": 518.66,
   "end": 519.54,
   "text": "We need to get the money"
  },
  {
   "start": 519.54,
   "end": 520.32,
   "text": "Off the billionaires"
  },
  {
   "start": 520.32,
   "end": 521.22,
   "text": "And get them"
  },
  {
   "start": 521.22,
   "end": 521.76,
   "text": "Make them"
  },
  {
   "start": 521.76,
   "end": 522.72,
   "text": "So they're not so dangerous"
  },
  {
   "start": 522.72,
   "end": 525.12,
   "text": "So that's the law"
  },
  {
   "start": 525.12,
   "end": 525.92,
   "text": "That I propose"
  },
  {
   "start": 525.92,
   "end": 526.5,
   "text": "There should be"
  },
  {
   "start": 526.5,
   "end": 527.2,
   "text": "No billionaires"
  },
  {
   "start": 527.2,
   "end": 528.1,
   "text": "Let's get it passed"
  },
  {
   "start": 528.1,
   "end": 529.96,
   "text": "Let's have us all"
  },
  {
   "start": 529.96,
   "end": 530.44,
   "text": "Vote on it"
  },
  {
   "start": 530.44,
   "end": 532.06,
   "text": "90% says yes"
  },
  {
   "start": 532.06,
   "end": 534.8,
   "text": "No more billionaires"
  },
  {
   "start": 534.8,
   "end": 541.48,
   "text": "Thanks"
  },
  {
   "start": 541.48,
   "end": 542.28,
   "text": "You"
  },
  {
   "start": 542.28,
   "end": 543.48,
   "text": "You"
  },
  {
   "start": 543.48,
   "end": 551.88,
   "text": "You"
  }
 ]
}