   "text": "And then you probably get"
  },
  {
   "start": 445.24,
   "end": 446.24,
   "text": "Some other kind of a job"
  },
  {
   "start": 446.24,
   "end": 447.24,
   "text": "Cosmic job"
  },
  {
   "start": 447.24,
   "end": 448.24,
   "text": "Where you oversee"
  },
  {
   "start": 448.24,
   "end": 449.24,
   "text": "Like a planet or something"
  },
  {
   "start": 449.24,
   "end": 450.24,
   "text": "You know"
