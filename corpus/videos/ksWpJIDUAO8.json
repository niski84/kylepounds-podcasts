   "text": "The universe expands"
  },
  {
   "start": 455.24,
   "end": 456.24,
   "text": "It's just all these little"
  },
  {
   "start": 456.24,
   "end": 457.24,
   "text": "You know"
  },
  {
   "start": 457.24,
   "end": 458.24,
   "text": "I think space is infinite"
  },
  {
   "start": 458.24,
   "end": 459.24,
   "text": "But matter is not infinite"
