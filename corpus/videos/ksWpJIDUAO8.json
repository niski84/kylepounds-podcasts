   "text": "Is what I"
  },
  {
   "start": 475.24,
   "end": 477.24,
   "text": "Makes me feel good about the world"
  },
  {
   "start": 477.24,
   "end": 478.24,
   "text": "I mean"
  },
  {
   "start": 478.24,
   "end": 479.24,
   "text": "What's"
  },
  {
   "start": 479.24,
   "end": 480.24,
   "text": "What's"
  },
  {
   "start": 480.24,
   "end": 481.24,
   "text": "What's wrong with thinking"
  },
  {
   "start": 481.24,
   "end": 482.24,
