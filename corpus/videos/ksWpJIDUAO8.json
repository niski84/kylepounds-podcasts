   "start": 484.24,
   "end": 485.24,
   "text": "Um"
  },
  {
   "start": 485.24,
   "end": 486.24,
   "text": "But"
  },
  {
   "start": 486.24,
   "end": 487.24,
   "text": "But like"
  },
  {
   "start": 487.24,
   "end": 488.24,
   "text": "And that's what Christians believe in"
  },
  {
   "start": 488.24,
   "end": 489.24,
