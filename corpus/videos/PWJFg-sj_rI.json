  {
   "start": 379.45,
   "end": 398.12,
   "text": "A simple word."
  },
  {
   "start": 519.48,
   "end": 520.52,
   "text": "Pakartotinai."
  },
  {
   "start": 520.9,
   "end": 523.04,
   "text": "Ir ko greišiausiai skelbiu."
  },
  {
   "start": 523.64,
   "end": 527.54,
   "text": "Kad pagal Seimo nutarimą ir žemės statutą."
  },
  {
   "start": 528.08,
   "end": 530.22,
   "text": "Nei mažumėlės, ne dėlsdami."
  },
  {
   "start": 530.96,
   "end": 533.74,
   "text": "Vygtumėt į mūsų karo tarnybą."
  },
  {
   "start": 534.08,
   "end": 535.7,
   "text": "Pastrakų vaivadą."
  },
  {
   "start": 535.9,
   "end": 538.06,
   "text": "Lietuvos didi atmona."
  },
  {
   "start": 538.28,
   "end": 541.54,
   "text": "Pona Mikaloju Jurgaiti Radvila."
  },
  {
   "start": 541.54,
   "end": 565.32,
   "text": "Honos etnonas mums pranešė, jog daugelis jūsų valdantis minėtose vaivadijose žemes ir iš jų gaudami naudą nebaisote Lietuvos statuto reikalavimu, neturėkit jokios vilties gauti lengvatų, neieškokite statute prie kabių nustatytom prievaliam apeiti,"
  },
  {
   "start": 565.32,
   "end": 579.64,
   "text": "Kuo skubiausiai valnokite žirdus ir prisijunkite prie savo bendrininkų, kurie susibūrė vaivadijų vėvlėvose, jau dabar kantriai ir garbingai pakelia karo sunkumus."
  },
  {
   "start": 579.64,
   "end": 592.76,
   "text": "Tie jūsų broliai atlieka savo pareigą gindami mūsų kraštą nuo įžūlaus priešo, jie gina ir tos tvarus, kurios dabar ties vėgėti išskaitygi jaujote."
  },
  {
   "start": 592.76,
   "end": 605.58,
   "text": "Nors pagal statutą, dėl pavėlavimo į tarnybą jau buvote savo dvarus praradę, tačiau mes iš savo malonės šiuo metu tai paliekame savo valioje."
  },
  {
   "start": 605.58,
   "end": 619.82,
   "text": "Vėl įsakome, kad nedėl zdami padarytume taip, kaip yra nurodyta, nes nepaklusdami prarasite ne tik savo dvarus, bet ir savo galvas."
  },
  {
   "start": 619.82,
   "end": 629.76,
   "text": "O kad mūsų įsakimas ir šitas raštas jūs pasiektų ir paskui nesidangskytume to, jog nežinojote,"
  },
  {
   "start": 630.34,
   "end": 639.64,
   "text": "Sliepėme mūsų miestuose ir turguose ir priešais mūsų valdovišką pilį įgalsiai paskelti ir iškapinti."
  },
  {
   "start": 639.64,
   "end": 646.38,
   "text": "Rašyta mūsų mieste Vilniuje vienas tūkstantis penkišimtai."
  }
 ]
