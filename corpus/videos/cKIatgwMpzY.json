  },
  {
   "start": 401.78,
   "end": 405.41,
   "text": "Those are the baths."
  },
  {
   "start": 405.41,
   "end": 406.41,
   "text": "Thaddeus."
  },
  {
   "start": 406.41,
   "end": 408.41,
   "text": "Temple of Zeus back there."
