  },
  {
   "start": 234.33,
   "end": 234.59,
   "text": "Building,"
  },
  {
   "start": 234.81,
   "end": 235.59,
   "text": "Or animals."
  },
  {
   "start": 236.61,
   "end": 237.79,
   "text": "Jungle animals right there."
  },
  {
   "start": 238.25,
   "end": 239.21,
   "text": "Turtles and,"
  },
  {
   "start": 240.81,
   "end": 241.19,
   "text": "Like,"
  },
  {
