  {
   "start": 418.44,
   "end": 419.58,
   "text": "I saw some Middle Easterners,"
  },
  {
   "start": 419.68,
   "end": 420.98,
   "text": "But, yes,"
  },
  {
   "start": 421.4,
   "end": 422.86,
