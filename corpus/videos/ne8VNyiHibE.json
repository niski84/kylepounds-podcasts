   "text": "Working at the,"
  },
  {
   "start": 393.04,
   "end": 394.78,
   "text": "At the convenience store."
  },
  {
   "start": 395.8,
   "end": 396.44,
   "text": "He was, uh,"
  },
  {
   "start": 396.44,
