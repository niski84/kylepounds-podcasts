  {
   "start": 188.26,
   "end": 188.5,
   "text": "Oh."
  },
  {
   "start": 188.74,
   "end": 190.64,
   "text": "People, they just didn't use minutes."
  },
  {
   "start": 190.82,
   "end": 191.14,
   "text": "Yeah."
  },
  {
   "start": 191.4,
   "end": 191.6,
   "text": "Yeah."
  },
  {
   "start": 191.68,
   "end": 192.84,
   "text": "It was good enough just to..."
  },
  {
   "start": 192.84,
   "end": 193.08,
   "text": "Exactly."
  },
  {
   "start": 193.24,
   "end": 194.66,
   "text": "So that's why sometimes people"
  },
  {
   "start": 194.66,
   "end": 196.08,
   "text": "Come to church quite angry."
  },
  {
   "start": 196.4,
   "end": 196.64,
   "text": "Uh-huh."
  },
  {
   "start": 196.64,
   "end": 197.26,
   "text": "These days, they say,"
  },
  {
   "start": 197.34,
   "end": 198.94,
   "text": "Excuse me, one has fallen off."
  },
  {
   "start": 199.1,
   "end": 199.3,
   "text": "Yeah."
  },
  {
   "start": 199.3,
   "end": 200.52,
   "text": "You should put it back right away."
  },
  {
   "start": 200.76,
   "end": 201.1,
   "text": "Uh-huh."
  },
  {
   "start": 201.1,
   "end": 201.7,
   "text": "To explain that,"
  },
  {
   "start": 201.76,
   "end": 202.64,
   "text": "No, that's the way it works."
  },
  {
   "start": 202.8,
   "end": 204.66,
   "text": "Because after the 15th century,"
  },
  {
   "start": 205.14,
   "end": 207.02,
   "text": "Other places started adding"
  },
  {
   "start": 207.02,
   "end": 208.18,
   "text": "The other one as well."
  },
  {
   "start": 208.4,
   "end": 208.6,
   "text": "Uh-huh."
  },
  {
   "start": 208.6,
   "end": 209.46,
   "text": "It's normal now."
  },
  {
   "start": 209.64,
   "end": 209.8,
   "text": "Yeah."
  },
  {
   "start": 209.8,
   "end": 211.02,
   "text": "But this church didn't,"
  },
  {
   "start": 211.02,
   "end": 211.48,
   "text": "So..."
