  {
   "start": 211.48,
   "end": 211.82,
   "text": "Uh-huh."
  },
  {
   "start": 211.82,
   "end": 213.52,
   "text": "We kept this tradition alive."
  },
  {
   "start": 213.74,
   "end": 214.04,
   "text": "Cool."
  },
  {
   "start": 214.3,
   "end": 215.24,
   "text": "But it still is"
  },
  {
   "start": 215.24,
   "end": 216.26,
   "text": "On the right time anyway,"
  },
  {
   "start": 216.26,
   "end": 216.98,
   "text": "So..."
