  {
   "start": 222.02,
   "end": 222.36,
   "text": "Okay."
  },
  {
   "start": 222.56,
   "end": 223.24,
   "text": "Yeah, yeah, yeah."
  },
  {
   "start": 223.24,
   "end": 225.12,
   "text": "And that's the government building"
  },
  {
   "start": 225.12,
