  {
   "start": 255.18,
   "end": 255.44,
   "text": "Uh-huh."
  },
  {
   "start": 255.88,
   "end": 256.18,
   "text": "And then,"
  },
  {
   "start": 256.3,
   "end": 256.92,
   "text": "When this tower"
  },
  {
