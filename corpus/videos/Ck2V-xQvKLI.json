   "start": 237.7,
   "end": 238.8,
   "text": "Right on the edge."
  },
  {
   "start": 239.32,
   "end": 240.14,
   "text": "We're kind of surrounded"
  },
  {
   "start": 240.14,
   "end": 240.8,
   "text": "By walls here."
  },
  {
   "start": 240.8,
   "end": 241.06,
   "text": "Yeah, yeah."
  },
  {
   "start": 241.06,
   "end": 241.98,
   "text": "This is the end"
