  },
  {
   "start": 207.71,
   "end": 209.85,
   "text": "Never connected to the, uh, the radar."
  },
  {
   "start": 210.01,
   "end": 211.93,
   "text": "I accidentally dipped the radar in water last night."
  },
  {
   "start": 213.45,
   "end": 215.63,
   "text": "Um, but it turned on, I wouldn't connect,"
  },
  {
   "start": 215.73,
