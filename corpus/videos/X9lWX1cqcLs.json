   "end": 374.74,
   "text": "And listening, uh, off YouTube."
  },
  {
   "start": 375.82,
   "end": 378.68,
   "text": "And then listening to them over and over and over and over again."
  },
  {
   "start": 378.72,
   "end": 383.0,
   "text": "Like, the same song, like, like, for, like, five days."
