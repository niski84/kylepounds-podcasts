   "text": "Or maybe it was 46."
  },
  {
   "start": 321.9,
   "end": 322.28,
   "text": "I don't know."
  },
  {
   "start": 322.64,
   "end": 324.58,
   "text": "See, I've been, like, really high, dude."
  },
  {
   "start": 325.8,
   "end": 326.46,
   "text": "Crazy high."
  },
  {
   "start": 326.56,
   "end": 327.36,
   "text": "Especially lately."
