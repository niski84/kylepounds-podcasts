   "text": "Those little green"
  },
  {
   "start": 446.16,
   "end": 447.8,
   "text": "Volkswagen bug taxis"
  },
  {
   "start": 447.8,
   "end": 448.5,
   "text": "All over the place."
  },
  {
   "start": 449.24,
   "end": 449.64,
   "text": "You go,"
  },
  {
   "start": 449.68,
   "end": 450.16,
   "text": "You go,"
  },
  {
   "start": 450.84,
   "end": 451.78,
   "text": "Hail down a taxi,"
  },
  {
   "start": 451.88,
   "end": 452.38,
   "text": "Hey taxi,"
  },
  {
   "start": 452.5,
   "end": 453.22,
   "text": "And it's driving by,"
  },
  {
   "start": 453.62,
   "end": 454.7,
   "text": "And you think you're going to have that,"
  },
  {
   "start": 454.74,
   "end": 455.44,
   "text": "Get that taxi,"
  },
  {
   "start": 456.04,
   "end": 456.28,
   "text": "And you're,"
  },
  {
   "start": 456.34,
   "end": 456.42,
   "text": "Okay,"
  },
  {
   "start": 456.5,
   "end": 457.7,
   "text": "That's the taxi I'm going to have."
  },
  {
   "start": 458.06,
   "end": 458.22,
   "text": "You know,"
  },
  {
   "start": 458.24,
   "end": 459.26,
   "text": "And all the taxis look the same."
  },
  {
   "start": 460.02,
   "end": 461.06,
   "text": "And then the taxi goes by,"
  },
  {
   "start": 461.14,
