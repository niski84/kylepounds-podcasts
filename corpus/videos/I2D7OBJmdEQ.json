   "text": "Oh no,"
  },
  {
   "start": 461.62,
   "end": 461.8,
   "text": "Okay,"
  },
  {
   "start": 461.88,
   "end": 462.64,
   "text": "Well I'll get this taxi."
  },
  {
   "start": 462.76,
   "end": 462.9,
   "text": "Boom,"
  },
  {
   "start": 462.94,
   "end": 463.56,
   "text": "When the taxi comes up,"
  },
  {
   "start": 463.58,
