  {
   "start": 474.46,
   "end": 474.82,
   "text": "Oh."
  },
  {
   "start": 476.46,
   "end": 477.36,
   "text": "You don't do that,"
  },
  {
   "start": 477.4,
   "end": 478.72,
   "text": "Because you just get in the next taxi."
  },
  {
   "start": 479.2,
   "end": 480.94,
   "text": "Well that's what the little zygote person does,"
  },
  {
   "start": 480.94,
   "end": 482.26,
   "text": "The little soul who's about to"
  },
  {
   "start": 482.26,
