   "text": "My life's over,"
  },
  {
   "start": 471.18,
   "end": 472.02,
   "text": "That taxi,"
  },
  {
   "start": 472.22,
   "end": 473.18,
   "text": "I hate that taxi,"
  },
  {
   "start": 473.34,
   "end": 473.52,
   "text": "Oh,"
  },
  {
   "start": 473.58,
